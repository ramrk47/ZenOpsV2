# Pilot wrapper variables for legacy/v1 hostinger compose services.
# Copy to: pilot-deployment/env/v1.env

# Compose project name
COMPOSE_PROJECT_NAME=zenops

# V1 public routing
ZENOPS_DOMAIN=zenops.example.com
TRAEFIK_CERTRESOLVER=letsencrypt
TRAEFIK_NETWORK=traefik-proxy

# Optional fixed image tags
# ZENOPS_API_IMAGE=ghcr.io/your-org/zenops-api:tag
# ZENOPS_FRONTEND_IMAGE=ghcr.io/your-org/zenops-frontend:tag

# V1 database
POSTGRES_DB=zenops
POSTGRES_USER=zenops
POSTGRES_PASSWORD=change_me

# Frontend build vars
VITE_API_URL=/api
VITE_V2_WEB_URL=https://repogen.example.com

# Backups host path
BACKUP_HOST_PATH=/opt/zenops/backups
BACKUP_RETENTION_DAYS=21

# Smoke defaults
V1_BASE_URL=https://zenops.example.com
V1_ADMIN_EMAIL=admin@zenops.local
V1_ADMIN_PASSWORD=change_me

