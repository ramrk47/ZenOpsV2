# Pilot wrapper variables for legacy/v1 repogen slice compose.
# Copy to: pilot-deployment/env/repogen.env

# Repogen routing
REPOGEN_DOMAIN=repogen.example.com
TRAEFIK_NETWORK=traefik-proxy
TRAEFIK_NETWORK_EXTERNAL=true
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# Host ports (local/testing)
REPOGEN_API_PORT=3000
REPOGEN_WEB_PORT=5174

# Runtime
REPOGEN_NODE_ENV=production
REPOGEN_LOG_LEVEL=info
REPOGEN_WORKER_CONCURRENCY=4
REPOGEN_JWT_SECRET=replace-with-strong-secret-at-least-32-chars

# Repogen isolated DB/Redis
REPOGEN_POSTGRES_DB=zenops
REPOGEN_POSTGRES_USER=postgres
REPOGEN_POSTGRES_PASSWORD=postgres
REPOGEN_DATABASE_URL_ROOT=postgresql://postgres:postgres@repogen-db:5432/zenops
REPOGEN_DATABASE_URL_API=postgresql://zen_api:zen_api@repogen-db:5432/zenops
REPOGEN_DATABASE_URL_WORKER=postgresql://zen_worker:zen_worker@repogen-db:5432/zenops
REPOGEN_REDIS_URL=redis://repogen-redis:6379

# Repogen web -> api
REPOGEN_PUBLIC_API_BASE_URL=https://repogen.example.com/v1

# Storage (R2 for pilot)
REPOGEN_STORAGE_DRIVER=s3
REPOGEN_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
REPOGEN_S3_REGION=auto
REPOGEN_S3_BUCKET=zenops-repogen
REPOGEN_S3_ACCESS_KEY_ID=<r2-access-key-id>
REPOGEN_S3_SECRET_ACCESS_KEY=<r2-secret-access-key>
REPOGEN_S3_FORCE_PATH_STYLE=true

# Smoke defaults
REPOGEN_BASE_URL=https://repogen.example.com
REPOGEN_WEB_URL=https://repogen.example.com
REPOGEN_INTERNAL_TENANT_ID=11111111-1111-1111-1111-111111111111

