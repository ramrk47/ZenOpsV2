ENVIRONMENT=production
PILOT_MODE=1
DATABASE_URL=postgresql+psycopg2://zenops:change_me@db:5432/zenops
JWT_SECRET=change_me
ADMIN_MASTER_KEY=change_me_admin_master_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
ALLOW_DESTRUCTIVE_ACTIONS=false
PUBLIC_BASE_URL=https://zenops.example.com

# Backups (optional)
# BACKUP_DIR=/app/backups
# LOCAL_BACKUP_TARGET=/mnt/backup-drive/zenops
# REMOTE_BACKUP_TARGET=user@host:/srv/zenops-backups
# GDRIVE_RCLONE_REMOTE=drive:zenops-backups

# CORS (comma-separated, lock to production origin)
ALLOW_ORIGINS=https://example.com

# Uploads
UPLOADS_DIR=/app/uploads
MAX_UPLOAD_MB=25
ALLOWED_UPLOAD_EXTENSIONS=pdf,jpg,jpeg,png,docx,xlsx
ALLOWED_UPLOAD_CONTENT_TYPES=application/pdf,image/jpeg,image/png,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
AV_SCAN_ENABLED=0

# V1 -> V2 Studio billing handshake
STUDIO_BASE_URL=https://api-zenops.notalonestudios.com
STUDIO_SERVICE_TOKEN=change_me_service_token
DEFAULT_BILLING_MODE=POSTPAID
STUDIO_HTTP_TIMEOUT_SECONDS=5
STUDIO_STATUS_CACHE_SECONDS=45

# Backup admin PIN (secondary factor for backup actions)
BACKUP_ADMIN_PIN=change_me
BACKUP_DIR=/backups

# Auth rate limits
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=10
RATE_LIMIT_LOGIN_IP_MAX=10
RATE_LIMIT_LOGIN_IP_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_EMAIL_MAX=5
RATE_LIMIT_LOGIN_EMAIL_WINDOW_SECONDS=60
RATE_LIMIT_REQUEST_ACCESS_IP_MAX=3
RATE_LIMIT_REQUEST_ACCESS_IP_WINDOW_SECONDS=86400
RATE_LIMIT_REQUEST_ACCESS_EMAIL_MAX=2
RATE_LIMIT_REQUEST_ACCESS_EMAIL_WINDOW_SECONDS=86400
RATE_LIMIT_PASSWORD_RESET_EMAIL_MAX=3
RATE_LIMIT_PASSWORD_RESET_EMAIL_WINDOW_SECONDS=3600

# Email delivery
# EMAIL_PROVIDER=disabled # resend | postmark | smtp | disabled
# EMAIL_API_KEY=
# EMAIL_FROM=no-reply@example.com
# APP_BASE_URL=https://app.example.com
# EMAIL_MAX_ATTEMPTS=3
# EMAIL_RETRY_MINUTES=5
# EMAIL_DEDUPE_MINUTES=60
# EMAIL_DAILY_LIMIT=20
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true

# E2E test-only associate onboarding shortcut (non-production only)
# ASSOCIATE_AUTO_APPROVE=0
# ASSOCIATE_AUTO_APPROVE_PASSWORD=password

# Associate onboarding mode controls
# ASSOCIATE_ONBOARDING_MODE=INVITE_ONLY|REQUEST_ACCESS_REVIEW|REQUEST_ACCESS_AUTO_APPROVE
ASSOCIATE_ONBOARDING_MODE=REQUEST_ACCESS_REVIEW
# Associate onboarding email delivery mode: email | disabled (disabled is non-production fallback only)
ASSOCIATE_EMAIL_MODE=email
ASSOCIATE_EMAIL_VERIFY_REQUIRED=1
ASSOCIATE_VERIFY_TOKEN_TTL_MINUTES=15
# Optional allowlist for auto-approve mode
ASSOCIATE_AUTO_APPROVE_DOMAINS=
ASSOCIATE_AUTO_APPROVE_MAX_PER_DAY=25

# DB pool tuning
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Build metadata
GIT_SHA=
BUILD_VERSION=
LOG_LEVEL=INFO

# Gunicorn workers
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
