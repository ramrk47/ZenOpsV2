# Docker Compose (Hostinger + Traefik)
# Use with: docker compose -f docker-compose.hostinger.yml -p zenops ...

# Project isolation
COMPOSE_PROJECT_NAME=zenops

# Public domain routed by Traefik
ZENOPS_DOMAIN=zenops.example.com
TRAEFIK_CERTRESOLVER=letsencrypt

# Optional image tags (for pull/rollback workflows)
# ZENOPS_API_IMAGE=ghcr.io/your-org/zenops-api:2026.02.11
# ZENOPS_FRONTEND_IMAGE=ghcr.io/your-org/zenops-frontend:2026.02.11
# ZENOPS_BACKUP_IMAGE=ghcr.io/your-org/zenops-backup:2026.02.11

# Database
POSTGRES_DB=zenops
POSTGRES_USER=zenops
POSTGRES_PASSWORD=change_me

# Frontend build: same-origin API via /api
VITE_API_URL=/api
VITE_PILOT_MODE=1
VITE_ENABLE_REPOGEN_INPUTS=0

# Backups
BACKUP_HOST_PATH=/opt/zenops/backups
RETAIN_LOCAL_DAYS=21
RETAIN_REMOTE_DAYS=30
BACKUP_RETENTION_DAYS=21

# Backend runtime essentials (copy to .env.backend in production)
ENVIRONMENT=production
PILOT_MODE=1
ALLOW_ORIGINS=https://zenops.example.com
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars
ADMIN_MASTER_KEY=change_me_admin_master_key
PUBLIC_BASE_URL=https://zenops.example.com
UPLOADS_DIR=/app/uploads
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
RATE_LIMIT_LOGIN_IP_MAX=10
RATE_LIMIT_LOGIN_IP_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_EMAIL_MAX=5
RATE_LIMIT_LOGIN_EMAIL_WINDOW_SECONDS=60
RATE_LIMIT_REQUEST_ACCESS_IP_MAX=3
RATE_LIMIT_REQUEST_ACCESS_IP_WINDOW_SECONDS=86400
RATE_LIMIT_REQUEST_ACCESS_EMAIL_MAX=2
RATE_LIMIT_REQUEST_ACCESS_EMAIL_WINDOW_SECONDS=86400
RATE_LIMIT_PASSWORD_RESET_EMAIL_MAX=3
RATE_LIMIT_PASSWORD_RESET_EMAIL_WINDOW_SECONDS=3600

# Associate onboarding mode
ASSOCIATE_ONBOARDING_MODE=INVITE_ONLY
ASSOCIATE_EMAIL_MODE=email
ASSOCIATE_EMAIL_VERIFY_REQUIRED=1
ASSOCIATE_VERIFY_TOKEN_TTL_MINUTES=15
ASSOCIATE_AUTO_APPROVE_DOMAINS=
ASSOCIATE_AUTO_APPROVE_MAX_PER_DAY=25

# Optional rclone sync (keep config outside git)
# RCLONE_SECRETS_DIR=/opt/zenops/secrets
# RCLONE_REMOTE=gdrive:zenops-backups
# BACKUP_ENCRYPTION_KEY=change_me_to_a_long_random_value
